const jsonLdGame = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Honey, I\'m an Agent',
  description: 'Acción, sigilo y comedia noir en 2D. Un hombre inofensivo termina por accidente como agente secreto.',
  genre: ['Action', 'Adventure', 'Indie'],
  gamePlatform: 'PC',
  applicationCategory: 'Game',
  author: { '@type': 'Organization', name: 'Multinow' },
  publisher: { '@type': 'Organization', name: 'Multinow' },
  datePublished: '2026-09-01',
  image: 'https://multinow-games.com/capsula_promocion_748.png',
