---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const screenshots = [
  { src: '/Screenshot_2.png', alt: 'Honey Im an Agent — captura 1' },
  { src: '/Screenshot_game_8.png', alt: 'Honey Im an Agent — captura 2' },
  { src: '/Screenshot_game_9.png', alt: 'Honey Im an Agent — captura 3' },
  { src: '/Screenshot%20_5.png', alt: 'Honey Im an Agent — captura 4' },
  { src: '/Screenshot_1.png', alt: 'Honey Im an Agent — captura 5' },
  { src: '/Screenshot_4.png', alt: 'Honey Im an Agent — captura 6' },
];

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>`,
    title: 'Doble Vida y Humor Ácido',
    desc: 'Narrativa donde el peligro criminal y los secretos domésticos se mezclan con situaciones hilarantes.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    title: 'Mecánica de Gancho y Paraguas',
    desc: 'Domina las físicas del grappling hook para desplazarte dinámicamente y usa tu paraguas como paracaídas y arma.',
