          </div>
        </div>

        <!-- Sidebar -->
        <aside class="game-sidebar">
          <div class="sidebar-card">
            <img src="/icono_acceso_directo.png" alt="Honey Im an Agent — icono" class="sidebar-card__icon" />
            <dl class="game-meta">
              <div class="game-meta__row">
                <dt>Título</dt>
                <dd>Honey, I'm an Agent</dd>
              </div>
              <div class="game-meta__row">
                <dt>Género</dt>
                <dd>Acción · Aventura · Indie</dd>
              </div>
              <div class="game-meta__row">
                <dt>Desarrollador</dt>
                <dd>Multinow</dd>
              </div>
              <div class="game-meta__row">
                <dt>Editor</dt>
                <dd>Multinow</dd>
              </div>
              <div class="game-meta__row">
                <dt>Jugadores</dt>
                <dd>Single Player</dd>
              </div>
              <div class="game-meta__row game-meta__row--release">
                <dt>Lanzamiento</dt>
                <dd class="game-meta__release-date">1 Sep 2026</dd>
              </div>
            </dl>
            <a href="https://store.steampowered.com" target="_blank" rel="noopener noreferrer" class="sidebar-btn-steam">
              <span class="btn-steam__top">Agregar a Wishlist</span>
              <span class="btn-steam__bottom">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.455 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/></svg>
                Steam
              </span>
            </a>
          </div>
        </aside>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  function initLightbox() {
    const grid = document.getElementById('screenshotsGrid');
    const lightbox = document.getElementById('lightbox') as HTMLElement | null;
    const lbImg = document.getElementById('lbImg') as HTMLImageElement | null;
    const lbClose = document.getElementById('lbClose');
    const lbPrev = document.getElementById('lbPrev');
    const lbNext = document.getElementById('lbNext');
    const lbCounter = document.getElementById('lbCounter');
    const backdrop = lightbox?.querySelector('.lightbox__backdrop');

    if (!grid || !lightbox || !lbImg) return;

    const items = Array.from(grid.querySelectorAll<HTMLButtonElement>('[data-lightbox-src]'));
    let current = 0;

    function open(index: number) {
      current = index;
      const item = items[current];
      lbImg!.src = item.dataset.lightboxSrc!;
      lbImg!.alt = item.dataset.lightboxAlt ?? '';
      if (lbCounter) lbCounter.textContent = `${current + 1} / ${items.length}`;
      lightbox!.hidden = false;
      document.body.style.overflow = 'hidden';
      lbImg!.classList.remove('lightbox__img--loaded');
      lbImg!.onload = () => lbImg!.classList.add('lightbox__img--loaded');
    }

    function close() {
      lightbox!.hidden = true;
      document.body.style.overflow = '';
    }

    function prev() { open((current - 1 + items.length) % items.length); }
    function next() { open((current + 1) % items.length); }

    items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
    lbClose?.addEventListener('click', close);
    lbPrev?.addEventListener('click', prev);
    lbNext?.addEventListener('click', next);
    backdrop?.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (lightbox!.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') prev();
      if (e.key === 'ArrowRight') next();
    });

    // Touch swipe
    let touchStartX = 0;
    lightbox.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      const delta = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 50) delta > 0 ? next() : prev();
    });
  }

  document.addEventListener('astro:page-load', initLightbox);
</script>

<style>
  /* ═══════ BASE ═══════ */
  .game-page {
    padding-top: 72px;
    background: var(--bg-dark);
    min-height: 100vh;
  }

  /* ═══════ HERO ═══════ */
  .game-hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4rem;
  }

  .game-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .game-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 40%, rgba(123, 47, 247, 0.18) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(0, 212, 255, 0.08) 0%, transparent 60%),
      linear-gradient(180deg, rgba(7,7,26,0) 0%, rgba(7,7,26,0.9) 100%);
  }

  .game-hero__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4;
  }

  .game-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr;
    gap: 2rem 4rem;
    align-items: center;
  }

  .game-hero__logo-wrap {
    grid-column: 1;
    grid-row: 1;
  }

  .game-hero__logo {
    max-width: 340px;
    width: 100%;
    filter: drop-shadow(0 0 32px rgba(123, 47, 247, 0.5));
  }

  .game-hero__content {
    grid-column: 1;
    grid-row: 2;
  }

  .game-hero__capsule-wrap {
    grid-column: 2;
    grid-row: 1 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-hero__capsule {
    width: 100%;
    max-width: 460px;
    border-radius: 12px;
    box-shadow:
      0 0 0 1px rgba(123, 47, 247, 0.3),
      0 24px 64px rgba(0, 0, 0, 0.6),
      0 0 48px rgba(123, 47, 247, 0.2);
    image-rendering: pixelated;
  }

  .game-hero__badges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
  }

  .badge--coming {
    background: rgba(245, 197, 66, 0.12);
    color: #f5c542;
    border: 1px solid rgba(245, 197, 66, 0.3);
  }

  .badge--date {
    background: rgba(123, 47, 247, 0.15);
    color: var(--purple-light);
    border: 1px solid rgba(123, 47, 247, 0.35);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }

  .badge--date::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f5c542;
    box-shadow: 0 0 6px rgba(245, 197, 66, 0.6);
    animation: pulse-dot 2s infinite;
    flex-shrink: 0;
  }

  .game-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .game-hero__tagline {
    font-family: var(--font-display);
    font-size: clamp(0.8rem, 1.8vw, 1rem);
    color: var(--cyan);
    letter-spacing: 0.04em;
    margin-bottom: 0.85rem;
    line-height: 1.3;
  }

  .game-hero__sub {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 520px;
  }

  .game-hero__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-steam {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.9rem 2rem;
    background: linear-gradient(135deg, #1b2838 0%, #2a475e 100%);
    color: #c6d4df;
    font-family: var(--font-display);
    text-transform: uppercase;
    border-radius: 8px;
    border: 1px solid rgba(198, 212, 223, 0.2);
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .btn-steam__top {
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .btn-steam__bottom {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    opacity: 0.75;
    line-height: 1;
  }

