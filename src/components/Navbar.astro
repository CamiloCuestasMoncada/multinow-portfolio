---
const navServices = [
  {
    label: 'Educativo',
    href: '/servicios/educativo',
    color: '#9373cb',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 9L12 4 2 9l10 5 10-5z"/><path d="M6 11.5V17s2.5 3 6 3 6-3 6-3v-5.5"/><line x1="22" y1="9" x2="22" y2="15"/></svg>`,
  },
  {
    label: 'Para Marcas',
    href: '/servicios/marcas',
    color: '#651fcf',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  },
  {
    label: 'Campañas',
    href: '/servicios/campanas',
    color: '#1371ef',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  },
  {
    label: 'A Medida',
    href: '/servicios/medida',
    color: '#0506a6',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-9"/><path d="M12.5 2.5l1 2 2 1-2 1-1 2-1-2-2-1 2-1z"/><path d="M20 8.5l.5 1 1 .5-1 .5-.5 1-.5-1-1-.5 1-.5z"/><path d="M8 7.5l.5 1 1 .5-1 .5-.5 1-.5-1-1-.5 1-.5z"/></svg>`,
  },
];
---
<header class="navbar">
  <div class="container navbar__inner">
    <a href="/#inicio" class="navbar__brand">
      <img src="/logo.png" alt="Multinow" class="navbar__logo" />
    </a>
    <nav class="navbar__nav" id="mainNav">
      <a href="/#inicio" class="nav__link">Inicio</a>

      <!-- Servicios dropdown -->
      <div class="nav__dropdown" id="servDropdown">
        <button class="nav__link nav__dropdown-toggle" aria-expanded="false" aria-haspopup="true" id="servToggle">
          Servicios
          <svg class="nav__chevron" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M1 1l5 5 5-5"/>
          </svg>
        </button>
        <div class="nav__dropdown-menu" role="menu">
          {navServices.map((s) => (
            <a href={s.href} class="nav__dropdown-item" role="menuitem">
              <span class="nav__dropdown-icon" style={`color:${s.color}`} set:html={s.icon} />
              <span>{s.label}</span>
            </a>
          ))}
          <div class="nav__dropdown-footer">
            <a href="/#servicios" class="nav__dropdown-all">Ver todos los servicios →</a>
          </div>
        </div>
      </div>

      <a href="/#soluciones" class="nav__link">Soluciones</a>
    </nav>
    <button class="navbar__toggle" aria-label="Abrir menú" id="menuToggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  function initNavbar() {
    const menuToggle = document.getElementById('menuToggle');
    const nav = document.getElementById('mainNav');
    const servToggle = document.getElementById('servToggle');
    const servDropdown = document.getElementById('servDropdown');

    if (!menuToggle || !nav || !servToggle || !servDropdown) return;

    // Mobile hamburger
    menuToggle.addEventListener('click', () => {
      nav.classList.toggle('navbar__nav--open');
      menuToggle.classList.toggle('navbar__toggle--open');
    });

    // Close mobile menu on link click
    document.querySelectorAll('.nav__link:not(.nav__dropdown-toggle), .nav__dropdown-item, .nav__dropdown-all').forEach(link => {
      link.addEventListener('click', () => {
        nav.classList.remove('navbar__nav--open');
        menuToggle.classList.remove('navbar__toggle--open');
        servDropdown.classList.remove('nav__dropdown--open');
        servToggle.setAttribute('aria-expanded', 'false');
      });
    });

    // Dropdown toggle — stopPropagation evita que el click llegue al documento
    servToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = servDropdown.classList.toggle('nav__dropdown--open');
      servToggle.setAttribute('aria-expanded', String(isOpen));
    });

    // Cerrar al hacer click fuera
    document.addEventListener('click', () => {
      servDropdown.classList.remove('nav__dropdown--open');
      servToggle.setAttribute('aria-expanded', 'false');
    });

    // Evitar que clicks dentro del menu lo cierren
    servDropdown.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  }

  // Inicializar en carga normal y en cada transición de View Transitions
  document.addEventListener('astro:page-load', initNavbar);
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background: rgba(7, 7, 26, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(123, 47, 247, 0.15);
    transition: background 0.3s;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar__brand { flex-shrink: 0; }

  .navbar__logo {
    height: 36px;
    display: block;
  }

  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-left: auto;
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cyan);
    transition: width 0.3s;
  }

  .nav__link:hover,
  .nav__dropdown--open .nav__dropdown-toggle {
    color: var(--cyan);
  }

  .nav__link:hover::after,
  .nav__dropdown--open .nav__dropdown-toggle::after {
    width: 100%;
  }

  /* CHEVRON */
  .nav__chevron {
    width: 10px;
    height: 10px;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .nav__dropdown--open .nav__chevron {
    transform: rotate(180deg);
  }

  /* DROPDOWN WRAPPER */
  .nav__dropdown {
    position: relative;
  }

  /* DROPDOWN MENU */
  .nav__dropdown-menu {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 220px;
    background: rgba(10, 10, 35, 0.97);
    border: 1px solid rgba(123, 47, 247, 0.25);
    border-radius: 14px;
    padding: 0.5rem;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(123, 47, 247, 0.1),
      0 0 32px rgba(123, 47, 247, 0.12);
    backdrop-filter: blur(16px);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  /* Desktop: show only when open class present (click-only) */
  @media (min-width: 769px) {
    .nav__dropdown--open .nav__dropdown-menu {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Mobile: show only via JS class */
  @media (max-width: 768px) {
    .nav__dropdown--open .nav__dropdown-menu {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Dropdown arrow pointer */
  .nav__dropdown-menu::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    background: rgba(10, 10, 35, 0.97);
    border-left: 1px solid rgba(123, 47, 247, 0.25);
    border-top: 1px solid rgba(123, 47, 247, 0.25);
    rotate: 45deg;
  }

  .nav__dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.65rem 0.85rem;
    border-radius: 9px;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: background 0.2s, color 0.2s;
  }

  .nav__dropdown-item:hover {
    background: rgba(123, 47, 247, 0.12);
    color: #fff;
  }

  .nav__dropdown-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav__dropdown-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .nav__dropdown-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 0.3rem;
    padding-top: 0.3rem;
  }

  .nav__dropdown-all {
    display: block;
    padding: 0.55rem 0.85rem;
    font-size: 0.68rem;
    font-family: var(--font-display);
    letter-spacing: 0.05em;
    color: var(--cyan);
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .nav__dropdown-all:hover {
    opacity: 1;
  }

  /* HAMBURGER */
  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .navbar__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .navbar__toggle--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .navbar__toggle--open span:nth-child(2) { opacity: 0; }
  .navbar__toggle--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* MOBILE NAV */
  @media (max-width: 768px) {
    .navbar__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: rgba(7, 7, 26, 0.98);
      border-top: 1px solid rgba(123, 47, 247, 0.2);
      padding: 0.5rem 0 1rem;
      margin-left: 0;
    }

    .navbar__nav--open { display: flex; }

    .nav__link,
    .nav__dropdown-toggle {
      padding: 0.9rem 1.5rem;
      justify-content: space-between;
    }

    .nav__dropdown { position: static; }

    .nav__dropdown-menu {
      position: static;
      transform: none !important;
      box-shadow: none;
      border: none;
      border-radius: 0;
      background: rgba(255, 255, 255, 0.03);
      border-top: 1px solid rgba(123, 47, 247, 0.1);
      padding: 0.25rem 0;
      min-width: unset;
    }

    .nav__dropdown-menu::before { display: none; }

    .nav__dropdown-item {
      padding: 0.75rem 2rem;
      border-radius: 0;
    }

    .nav__dropdown-footer { margin: 0; padding: 0; border: none; }

    .nav__dropdown-all {
      padding: 0.75rem 2rem;
    }

    .navbar__toggle { display: flex; }
  }
</style>
