---
---
<footer class="footer">
  <div class="footer__bg-img"></div>
  <div class="footer__bg-color"></div>
  <div class="footer__bg-overlay"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src="/logo.png" alt="Multinow" class="footer__logo" />
      <p class="footer__tagline">Videojuegos a medida en 2D</p>
    </div>
    <nav class="footer__nav">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#soluciones">Soluciones</a>
    </nav>
    <div class="footer__contact">
      <span id="footer-email" class="footer__email"></span>
    </div>
  </div>
  <div class="footer__bottom">
    <p>© {new Date().getFullYear()} Multinow. Todos los derechos reservados.</p>
    <p class="footer__location">📍 Bogotá, Colombia</p>
  </div>
</footer>

<script>
  function initFooterEmail() {
    const el = document.getElementById('footer-email');
    if (!el) return;
    const u = 'contacto';
    const d = 'multinow-games.com';
    const a = document.createElement('a');
    a.href = `mailto:${u}@${d}`;
    a.textContent = `${u}@${d}`;
    a.className = 'footer__email';
    el.replaceWith(a);
  }

  document.addEventListener('astro:page-load', initFooterEmail);
</script>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(123, 47, 247, 0.3);
    padding: 3rem 0 1.5rem;
    background: var(--bg-dark);
  }

  .footer__bg-img {
    position: absolute;
    inset: 0;
    background-image: url('/bgMecanicas.png');
    background-size: cover;
    background-position: center;
    mix-blend-mode: screen;
    opacity: 0.10;
    filter: invert(1) sepia(1) hue-rotate(250deg) saturate(5) brightness(0.75) contrast(1.2);
    z-index: 0;
  }

  .footer__bg-color {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, #3b95e3, #e871f1, #3b95e3);
    background-size: 200% 100%;
    mix-blend-mode: color;
    opacity: 0.95;
    z-index: 1;
    pointer-events: none;
    animation: footerGradient 15s ease-in-out infinite;
  }

  /* Fade superior + oscurecimiento uniforme para contraste de textos */
  .footer__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--bg-dark) 0%,
      rgba(7,7,26,0.62) 30%,
      rgba(7,7,26,0.62) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  @keyframes footerGradient {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .footer__inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 3rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  .footer__logo {
    height: 40px;
    margin-bottom: 0.5rem;
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
    text-shadow: 0 1px 10px rgba(0,0,0,0.9), 0 0 20px rgba(0,0,0,0.7);
  }

  .footer__nav {
    display: flex;
    gap: 2rem;
  }

  .footer__nav a {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.72);
    transition: color 0.2s;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 8px rgba(0,0,0,0.9);
  }

  .footer__nav a:hover {
    color: var(--cyan);
  }

  .footer__email {
    font-size: 0.875rem;
    color: var(--cyan);
    transition: opacity 0.2s;
    text-shadow: 0 1px 8px rgba(0,0,0,0.9);
  }

  .footer__email:hover {
    opacity: 0.8;
  }

  .footer__bottom {
    position: relative;
    z-index: 3;
    text-align: center;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.55);
    text-shadow: 0 1px 8px rgba(0,0,0,0.9);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__location {
    font-size: 0.72rem;
    color: rgba(200, 210, 230, 0.55);
    text-shadow: 0 1px 6px rgba(0,0,0,0.9);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }
    .footer__nav {
      justify-content: center;
    }
    .footer__logo {
      margin: 0 auto 0.5rem;
      display: block;
    }
  }
</style>
