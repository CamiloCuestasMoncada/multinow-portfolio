---
const servicios = [
  {
    id: 'educativo',
    label: 'Educativo',
    tagline: 'Gamificación educativa · Aprendizaje a través del juego',
    desc: 'Videojuegos pedagógicos 2D para colegios, universidades y LMS. Integración SCORM para reportar progreso y notas.',
    bg: '/bg_cultivo.png',
    c1: 'rgba(147,115,203,0.96)',
    c2: 'rgba(147,115,203,0.62)',
    c3: 'rgba(147,115,203,0.08)',
    glow: 'rgba(147,115,203,0.55)',
    borderHover: 'rgba(147,115,203,0.75)',
    bgFilter: 'invert(1) sepia(1) hue-rotate(240deg) saturate(3) brightness(1.4)',
    href: '/servicios/educativo',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 9L12 4 2 9l10 5 10-5z"/><path d="M6 11.5V17s2.5 3 6 3 6-3 6-3v-5.5"/><line x1="22" y1="9" x2="22" y2="15"/></svg>`,
  },
  {
    id: 'marcas',
    label: 'Para Marcas',
    tagline: 'Branded gaming experiences',
    desc: 'Juegos que integran tu identidad de marca de forma natural, generando recordación y engagement real con tu audiencia.',
    bg: '/bg_cafe.png',
    c1: 'rgba(101,31,207,0.96)',
    c2: 'rgba(101,31,207,0.62)',
    c3: 'rgba(101,31,207,0.08)',
    glow: 'rgba(101,31,207,0.55)',
    borderHover: 'rgba(101,31,207,0.75)',
    bgFilter: 'invert(1) sepia(1) hue-rotate(220deg) saturate(4) brightness(1.6)',
    href: '/servicios/marcas',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  },
  {
    id: 'campanas',
    label: 'Campañas',
    tagline: 'Activaciones digitales gamificadas',
    desc: 'Videojuegos que amplifican campañas publicitarias, aumentan la exposición a tu marca y generan contenido compartible.',
    bg: '/bgMecanicaTRansportadora.png',
    c1: 'rgba(19,113,239,0.96)',
    c2: 'rgba(19,113,239,0.62)',
    c3: 'rgba(19,113,239,0.08)',
    glow: 'rgba(19,113,239,0.55)',
    borderHover: 'rgba(19,113,239,0.75)',
    bgFilter: 'invert(1) sepia(1) hue-rotate(180deg) saturate(4) brightness(1.6)',
    href: '/servicios/campanas',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  },
  {
    id: 'medida',
    label: 'A Medida',
    tagline: 'Tu idea, hecha realidad',
    desc: 'Simuladores técnicos, instalaciones para eventos, minijuegos HTML5 o cualquier mecánica completamente personalizada.',
    bg: '/bg_engranajes.png',
    c1: 'rgba(5,6,166,0.96)',
    c2: 'rgba(5,6,166,0.62)',
    c3: 'rgba(5,6,166,0.08)',
    glow: 'rgba(5,6,166,0.55)',
    borderHover: 'rgba(5,6,166,0.75)',
    bgFilter: 'invert(1) sepia(1) hue-rotate(200deg) saturate(4) brightness(1.5)',
    href: '/servicios/medida',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-9"/><path d="M12.5 2.5l1 2 2 1-2 1-1 2-1-2-2-1 2-1z"/><path d="M20 8.5l.5 1 1 .5-1 .5-.5 1-.5-1-1-.5 1-.5z"/><path d="M8 7.5l.5 1 1 .5-1 .5-.5 1-.5-1-1-.5 1-.5z"/></svg>`,
  },
];
---

<section class="servicios" id="servicios">
  <div class="container">
    <h2 class="section__title">Nuestros Servicios</h2>
    <p class="section__sub">Videojuegos 2D personalizados para cada objetivo</p>

    <div class="scards">
      {servicios.map((s) => (
        <a
          href={s.href}
          class="scard"
          style={`--c1:${s.c1};--c2:${s.c2};--c3:${s.c3};--glow:${s.glow};--border-h:${s.borderHover};--bg-filter:${s.bgFilter};`}
        >
          <div class="scard__bg" style={`background-image:url('${s.bg}')`}></div>
          <div class="scard__overlay"></div>
          <div class="scard__content">
            <span class="scard__icon" set:html={s.icon} />
            <div class="scard__bottom">
              <p class="scard__tagline">{s.tagline}</p>
              <h3 class="scard__title">{s.label}</h3>
              <p class="scard__desc">{s.desc}</p>
              <span class="scard__cta">
                Ver servicio
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 10h12M10 4l6 6-6 6"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .servicios {
    padding: 6rem 0;
  }

  .section__title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    text-align: center;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--purple-light), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section__sub {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }

  /* GRID */
  .scards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* CARD */
  .scard {
    position: relative;
    height: 420px;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.07);
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .scard:hover {
    transform: translateY(-8px) scale(1.015);
    box-shadow:
      0 24px 64px var(--glow),
      0 0 0 1px var(--border-h);
    border-color: var(--border-h);
  }

  /* BACKGROUND IMAGE — inverted sketch lines tinted to card color */
  .scard__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: var(--bg-filter);
    opacity: 0.18;
    transition: transform 0.55s ease, opacity 0.35s ease;
  }

  .scard:hover .scard__bg {
    transform: scale(1.06);
    opacity: 0.26;
  }

  /* COLOR OVERLAY — color tint + dark scrim at bottom for text contrast */
  .scard__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.15) 38%, transparent 60%),
      linear-gradient(to top, var(--c1) 0%, var(--c2) 42%, var(--c3) 100%);
  }

  /* CONTENT */
  .scard__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
  }

  /* ICON — top left */
  .scard__icon {
    width: 46px;
    height: 46px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    color: #fff;
    flex-shrink: 0;
  }

  .scard__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  /* BOTTOM TEXT */
  .scard__bottom {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .scard__tagline {
    font-size: 0.75rem;
    font-family: var(--font-display);
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.35rem;
    text-shadow: 0 1px 6px rgba(0,0,0,0.7);
  }

  .scard__title {
    font-size: 1.45rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 0.6rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 1px 3px rgba(0,0,0,0.9);
  }

  .scard__desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.6;
    margin-bottom: 1.1rem;
    text-shadow: 0 1px 6px rgba(0,0,0,0.7);
  }

  /* CTA PILL */
  .scard__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    backdrop-filter: blur(10px);
    align-self: flex-start;
    transition: background 0.3s, border-color 0.3s;
  }

  .scard:hover .scard__cta {
    background: rgba(255, 255, 255, 0.24);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .scard__cta :global(svg) {
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease;
  }

  .scard:hover .scard__cta :global(svg) {
    transform: translateX(4px);
  }

  /* RESPONSIVE */
  @media (max-width: 1100px) {
    .scards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .scards {
      grid-template-columns: 1fr;
    }

    .scard {
      height: 340px;
    }
  }
</style>
