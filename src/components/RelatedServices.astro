---
interface Props {
  current: 'educativo' | 'marcas' | 'campaigns' | 'medida';
}

const { current } = Astro.props;

const all = [
  {
    id: 'educativo',
    label: 'Videojuegos Educativos',
    tagline: 'Gamificación educativa · SCORM',
    href: '/servicios/educativo',
    color: '#9373cb',
    rgb: '147,115,203',
  },
  {
    id: 'marcas',
    label: 'Videojuegos para Marcas',
    tagline: 'Branded gaming experiences',
    href: '/servicios/marcas',
    color: '#651fcf',
    rgb: '101,31,207',
  },
  {
    id: 'campaigns',
    label: 'Videojuegos para Campañas',
    tagline: 'Activaciones digitales gamificadas',
    href: '/servicios/campaigns',
    color: '#1371ef',
    rgb: '19,113,239',
  },
  {
    id: 'medida',
    label: 'Videojuegos a Medida',
    tagline: 'Tu idea, hecha realidad',
    href: '/servicios/medida',
    color: '#0506a6',
    rgb: '5,6,166',
  },
];

const related = all.filter((s) => s.id !== current);
---

<section class="related">
  <div class="container">
    <p class="related__label">También te puede interesar</p>
    <div class="related__grid">
      {related.map((s) => (
        <a
          href={s.href}
          class="related__card"
          style={`--c:${s.color};--rgb:${s.rgb};`}
        >
          <span class="related__tagline">{s.tagline}</span>
          <span class="related__title">{s.label}</span>
          <span class="related__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .related {
    padding: 4rem 0 5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .related__label {
    font-size: 0.72rem;
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    padding-left: 0.75rem;
    border-left: 2px solid rgba(255, 255, 255, 0.2);
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related__card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem 1.75rem;
    border-radius: 12px;
    border: 1px solid rgba(var(--rgb), 0.2);
    background: linear-gradient(135deg, rgba(var(--rgb), 0.07), transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }

  .related__card:hover {
    border-color: rgba(var(--rgb), 0.55);
    box-shadow: 0 0 24px rgba(var(--rgb), 0.18);
    transform: translateY(-3px);
  }

  .related__tagline {
    font-size: 0.68rem;
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c);
    opacity: 0.85;
  }

  .related__title {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  .related__arrow {
    font-size: 1.1rem;
    color: rgba(var(--rgb), 0.7);
    margin-top: 0.5rem;
    transition: transform 0.25s;
    display: inline-block;
  }

  .related__card:hover .related__arrow {
    transform: translateX(5px);
  }

  @media (max-width: 768px) {
    .related__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
