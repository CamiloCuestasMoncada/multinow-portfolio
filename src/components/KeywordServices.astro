---
const items = [
  {
    titulo: 'Gamificación para empresas:',
    desc: 'Diseñamos dinámicas de juego personalizadas para optimizar procesos de inducción, retención de conocimiento y motivación de equipos corporativos. Trabajamos con empresas en Colombia y Latinoamérica.',
  },
  {
    titulo: 'Juegos para plataformas E-learning:',
    desc: 'Desarrollamos experiencias lúdicas optimizadas y listas para integrarse fluidamente dentro de sistemas LMS empresariales o portales escolares interactivos.',
  },
  {
    titulo: 'Desarrollo 100% Personalizado y Alto Rendimiento:',
    desc: 'No usamos plantillas genéricas. Diseñamos la lógica de juego, el apartado visual y las mecánicas desde cero, garantizando una experiencia fluida, optimizada y perfectamente alineada con la identidad visual de tu marca o institución.',
  },
  {
    titulo: 'Videojuegos Web HTML5 y Multiplataforma:',
    desc: 'Desarrollamos soluciones interactivas adaptadas al ecosistema que requieras, ofreciendo despliegue inmediato en entornos Web HTML5 (sin descargas), aplicaciones nativas para móviles (Android e iOS), y ejecutables de escritorio para estaciones de trabajo (Windows, Mac y Linux).',
  },
  {
    titulo: 'Serious Games (Juegos Serios):',
    desc: 'Creamos simulaciones interactivas enfocadas en la resolución de problemas reales, entrenamiento técnico y educación corporativa con propósitos pedagógicos profundos.',
  },
  {
    titulo: 'Minijuegos para redes sociales:',
    desc: 'Diseñamos mecánicas casuales, atractivas y de corto alcance ideales para captar leads, potenciar el engagement de tu comunidad e impulsar campañas de marketing digital.',
  },
];
---

<section class="kw-services" id="soluciones">
  <div class="container">
    <h2 class="kw-services__title">Soluciones en Gamificación y Desarrollo de Videojuegos</h2>
    <div class="kw-services__grid">
      {items.map((item) => (
        <div class="kw-item">
          <span class="kw-item__check" aria-hidden="true">✓</span>
          <p class="kw-item__text">
            <strong>{item.titulo}</strong>{' '}{item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .kw-services {
    padding: 4rem 0;
    background: var(--bg-card);
    border-top: 1px solid rgba(123, 47, 247, 0.2);
    border-bottom: 1px solid rgba(123, 47, 247, 0.2);
  }

  .kw-services__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 700;
    color: var(--cyan);
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
  }

  .kw-services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .kw-services__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .kw-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(123, 47, 247, 0.15);
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .kw-item__check {
    color: var(--purple-light);
    font-size: 2rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
    text-shadow: 0 0 8px var(--purple-glow), 0 0 16px var(--purple-glow);
    animation: checkGlow 2.5s ease-in-out infinite;
  }

  @keyframes checkGlow {
    0%, 100% { text-shadow: 0 0 6px var(--purple-glow), 0 0 14px var(--purple-glow); }
    50%       { text-shadow: 0 0 14px rgba(168, 85, 247, 0.8), 0 0 28px rgba(168, 85, 247, 0.5); }
  }

  .kw-item__text {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .kw-item__text strong {
    color: var(--text);
    font-weight: 600;
  }
</style>
